---
import BaseLayout from "../layouts/BaseLayout.astro";
import CoreEditingApple1 from "../components/about/CoreEditingApple1.jsx";
import "@dilsonspickles/components/style.css";

const pageTitle = "Layout test · Hundreds of smaller things";
const pageDescription =
  "Sandbox for the Apple #1 filmstrip layout of Hundreds of smaller things.";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  showPromoBanner={false}
>
  <div class="layout-test-page">
    <CoreEditingApple1 client:visible />
  </div>
</BaseLayout>

<style is:global>
  html {
    --page-bg: rgb(10, 13, 26);
  }
  body {
    background-color: var(--page-bg) !important;
  }
  .layout-test-page {
    background: rgb(28, 22, 78);
  }
</style>
