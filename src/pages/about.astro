---
import BaseLayout from "../layouts/BaseLayout.astro";
import ScrollyLaptopTour from "../components/about/ScrollyLaptopTour/ScrollyLaptopTour.jsx";
import CreatorWorkflows from "../components/about/CreatorWorkflows.jsx";
import CoreEditing from "../components/about/CoreEditing.jsx";
import Workspaces from "../components/about/Workspaces.jsx";
import CustomisableUI from "../components/about/CustomisableUI.jsx";
import EffectWindows from "../components/about/EffectWindows.jsx";
import MuseHub from "../components/about/MuseHub.jsx";
import AudioCom from "../components/about/AudioCom.jsx";
import UnderTheHood from "../components/about/UnderTheHood.jsx";
import CtaSection from "../components/about/CtaSection.jsx";
import Interstitial from "../components/about/Interstitial.astro";
import TeamCall from "../components/about/team/TeamCall.jsx";
import "@dilsonspickles/components/style.css";

const pageTitle = "Audacity ® | Audacity 4";
const pageDescription = "Flagship tour of what's new in Audacity 4.";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  showPromoBanner={false}
>
  <div class="scroll-bg-page">
    <div class="about-section about-section--scrolly">
      <ScrollyLaptopTour client:visible />
    </div>
    <div class="about-section about-section--core-editing">
      <CoreEditing client:visible />
    </div>
    <div class="about-section about-section--workspaces">
      <Workspaces client:visible />
    </div>
    <div class="about-section about-section--customisable-ui">
      <CustomisableUI client:visible />
    </div>
    <div class="about-section about-section--audiocom">
      <AudioCom client:visible />
    </div>
    <div class="about-section about-section--creators">
      <CreatorWorkflows variant="hero" client:visible />
    </div>
    <div class="about-section about-section--effect-windows">
      <EffectWindows client:visible />
    </div>
    <div class="about-section about-section--musehub">
      <MuseHub client:visible />
    </div>
    <div class="about-section about-section--under-the-hood">
      <UnderTheHood client:visible />
    </div>
    <Interstitial from="#120927" to="rgb(8, 6, 28)" />
    <div class="about-section about-section--team">
      <TeamCall client:visible />
    </div>
    <div class="about-section about-section--cta">
      <CtaSection />
    </div>
  </div>
</BaseLayout>

<style is:global>
  html {
    --page-bg: rgb(10, 13, 26);
  }
  body {
    background-color: var(--page-bg) !important;
    /*
      Belt-and-braces clip on horizontal overflow. Something inside
      the page is wider than the viewport on some sizes (likely a
      demo's fixed-width inner container that's escaping its
      overflow-hidden ancestor). Killing the right-scroll at the body
      so the page stays single-column-scrolling while we hunt it.
    */
    overflow-x: hidden;
  }
  #site-header {
    position: fixed !important;
    top: 0;
    left: 0;
    right: 0;
    transform: translateY(0);
    background-color: transparent;
    transition:
      transform 280ms ease,
      background-color 240ms ease,
      backdrop-filter 240ms ease;
    will-change: transform;
  }
  #site-header[data-hidden="true"] {
    transform: translateY(-100%);
  }
  #site-header nav {
    background-color: transparent;
    transition:
      background-color 240ms ease,
      backdrop-filter 240ms ease;
  }
  #site-header:hover nav,
  #site-header:focus-within nav {
    background-color: rgba(10, 13, 22, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .scroll-bg-page .bg-background-dark {
    background-color: transparent !important;
  }

  .about-section {
    position: relative;
  }

  /*
    Three-layer sandwich for the chapter-break swoosh spill:
      Layer 1 (step 4 in the root stacking context): about-section wrappers
        — these carry the section's background colour. No explicit z-index.
      Layer 2 (z-index: 1): the .about-interstitial sections (see Interstitial
        .astro). Painting at step 5 puts the bleeding swoosh ABOVE every
        section's background (otherwise the next section's bg would clip
        the downward bleed in DOM order).
      Layer 3 (z-index: 2): each section's CONTENT (this rule). Text and
        imagery sit above the swoosh layer so they remain readable when the
        spill enters their territory.

    NOTE: `client:visible` sections are wrapped in <astro-island>, which is
    `display: contents` — so position/z-index set on it are ignored and the
    real content box below would fall back to z-index auto (0), letting the
    swoosh paint OVER it (that's the AudioCom/UnderTheHood overlap bug). The
    second selector reaches through the island to the actual content box.
  */
  .about-section > *,
  .about-section > astro-island > * {
    position: relative;
    z-index: 2;
  }

  .scroll-bg-page > .about-section:nth-child(n + 2),
  .scroll-bg-page > .about-section:nth-child(n + 2) section {
    /* svh (small viewport height) so section min-heights stay stable
       as mobile browser chrome shows/hides — dvh would grow/shrink on
       every scroll and cause the whole page to reflow. */
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /*
    Hero sits darker than the editor chapter (#1c164e) below so the
    laptop tour reads as its own quieter stage before the page opens
    up into the flat purple chapter.
  */
  .about-section--scrolly {
    background-color: #0e0c30;
  }
  /*
    Photography "who it's for" beat — replaces the first swoosh interstitial
    between AudioCom and the effects section. Carries the same top→bottom
    colour bridge the interstitial did (AudioCom #141336 → effects #0a0912)
    so the chapter transition is preserved.
  */
  .about-section--creators {
    background: linear-gradient(to bottom, #141336 0%, #0a0912 100%);
  }
  /*
    CoreEditing → Workspaces → CustomisableUI form one continuous chapter
    about the editor itself, so they share a single flat purple. Any
    seam between them would visually break up related content.
  */
  .about-section--core-editing,
  .about-section--workspaces,
  .about-section--customisable-ui {
    background-color: #1c164e;
  }
  /*
    Quieter indigo than the previous saturated blue so the AudioCom
    visual elements (logo, cloud graphics) sit forward rather than
    fighting a proud background.
  */
  .about-section--audiocom {
    background-color: #141336;
  }
  /*
    Effects section runs a dark-mode-esque stage — near-black with a
    subtle purple undertone — so the individual effect window UI
    mockups pop as bright product shots against a rich, quiet ground.
  */
  .about-section--effect-windows {
    background-color: #0a0912;
  }
  /*
    Muted violet drawn from MuseHub's #9B41FD accent — dark enough to
    sit back but hue-linked so the section feels tied to the brand
    without a saturated wash competing with the visuals.
  */
  .about-section--musehub {
    background-color: #1a0d36;
  }
  /*
    Darker relative of MuseHub's violet so the seam above reads as
    "going deeper into the tech" rather than a hue clash between two
    similarly-dark but differently-warm purples. Still bridges to
    CTA's near-black below.
  */
  .about-section--under-the-hood {
    background-color: #120927;
  }
  .about-section--team {
    background-color: rgb(8, 6, 28);
  }

  .about-section--cta {
    background-color: rgb(8, 6, 28);
  }
  /*
    Drop the footer's own dark backdrop on this page so it reads as a
    continuation of the CTA section — same colour, no seam.
  */
  body:has(.about-section--cta) footer.bg-background-dark {
    background-color: rgb(8, 6, 28);
  }
</style>

<script>
  function init() {
    const host = document.querySelector<HTMLElement>(".scroll-bg-page");
    if (!host) return;

    // Hide the site header when the user scrolls down. Show it again on
    // scroll up, near the very top of the page, or when the cursor moves
    // near the top edge of the viewport.
    const header = document.getElementById("site-header");
    let lastY = window.scrollY;
    let scrollHidden = false;
    let mouseAtTop = false;
    const HIDE_AFTER = 80; // px from top before scroll-hide kicks in
    const MOUSE_REVEAL_AT = 80; // px from top edge where the nav reappears
    const DELTA = 6; // ignore tiny scroll jitter

    function applyHeaderState() {
      if (!header) return;
      const shouldHide = scrollHidden && !mouseAtTop;
      if (shouldHide) header.setAttribute("data-hidden", "true");
      else header.removeAttribute("data-hidden");
    }

    function updateHeader() {
      const y = window.scrollY;
      const dy = y - lastY;
      if (Math.abs(dy) < DELTA) return;
      if (y < HIDE_AFTER) scrollHidden = false;
      else if (dy > 0) scrollHidden = true;
      else if (dy < 0) scrollHidden = false;
      lastY = y;
      applyHeaderState();
    }

    function onMouseMove(e: MouseEvent) {
      const near = e.clientY < MOUSE_REVEAL_AT;
      if (near !== mouseAtTop) {
        mouseAtTop = near;
        applyHeaderState();
      }
    }
    window.addEventListener("mousemove", onMouseMove, { passive: true });

    let raf: number | null = null;
    function onScroll() {
      if (raf !== null) return;
      raf = requestAnimationFrame(() => {
        updateHeader();
        raf = null;
      });
    }
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
