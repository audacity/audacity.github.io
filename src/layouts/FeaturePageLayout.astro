---
import BaseLayout from "./BaseLayout.astro";
import OsToggle from "../components/OsToggle.astro";

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
}

const { title, description, canonical, image } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  image={image}
>
  <slot name="hero" />
  <article
    class="mx-4 sm:mx-auto py-12 md:py-20 prose prose-blue prose-feature lg:prose-lg max-w-screen-md"
  >
    <OsToggle />
    <slot />
  </article>
</BaseLayout>
