---
import HeroSwoosh from "../homepage/HeroSwoosh.astro";

interface Props {
  from?: string;
  to?: string;
}

const { from = "rgb(28, 30, 108)", to = "rgb(86, 32, 78)" } = Astro.props;
---

<section
  class="about-interstitial"
  data-interstitial
  style={`background: linear-gradient(to bottom, ${from} 0%, ${to} 100%);`}
>
  <div class="about-interstitial__inner">
    <slot>
      <div class="about-interstitial__swoosh" data-interstitial-swoosh>
        <HeroSwoosh />
      </div>
    </slot>
  </div>
</section>

<style>
  .about-interstitial {
    /* Background set inline as a gradient between adjacent sections — no
       black band, just a smooth handoff with the swoosh blooming in the
       middle. */
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    overflow: visible;
    position: relative;
    /*
      z-index: 1 so the interstitial (and its bleeding swoosh) composites
      ABOVE all adjacent section backgrounds in the root stacking context.
      Section content has z-index: 2 (set in about.astro), keeping text
      above the spill. contain: layout — NOT paint, which would clip the
      spill.
    */
    z-index: 1;
    contain: layout;
  }

  .about-interstitial__inner {
    max-width: 60ch;
    text-align: center;
  }

  /*
    The swoosh wrapper carries the scroll-driven motion as a SINGLE transform
    on the whole SVG (not per-path). The HeroSwoosh's own path animations are
    disabled by the global override below, so the only work the browser does
    each frame is one transform/opacity update per visible interstitial.

    Absolutely positioned and centered in the interstitial so it sits as a
    big balanced graphic across the transition zone. position: absolute is
    required for z-index: -1 to actually apply — it pushes the swoosh
    behind the interstitial's in-flow content in this stacking context,
    and the section content above/below (z-index: 2 set in about.astro)
    keeps text painting over the swoosh in the root stacking context.
  */
  .about-interstitial__swoosh {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(80vw, 1400px);
    aspect-ratio: 669 / 554;
    will-change: transform, opacity;
    transform-origin: center;
    z-index: -1;
    opacity: var(--isw-p, 0);
    /*
      Base size already dominates the viewport — opacity drives the in/out,
      scale only breathes between 0.95 and 1.1 across the arc.
      translate(-50%, -50%) centers the wrapper on its own pivot.
    */
    transform: translate(-50%, -50%) scale(calc(0.95 + var(--isw-p, 0) * 0.15));
  }
</style>

<style is:global>
  /*
    Disable the HeroSwoosh's load-time fan-in + twitch animations when it's
    embedded inside an interstitial — the wrapper transform drives the motion
    here, and the per-path animations would otherwise burn CPU continuously.
  */
  [data-interstitial-swoosh] svg.hero-swoosh path {
    animation: none;
    opacity: 1;
    transform: none;
  }
</style>

<script>
  /*
    For each interstitial: as it crosses the viewport, set --isw-prog (raw
    0–1 progress) and --isw-p (bell-curve 0→1→0). The wrapper transform
    uses these to drive a big rotation + scale that bleeds the fan out past
    the band's edges at peak. Updates are skipped for any interstitial
    further than one viewport from the current scroll.
  */
  const els = document.querySelectorAll<HTMLElement>("[data-interstitial]");
  if (els.length) {
    const targets = Array.from(els)
      .map((el) => ({
        el,
        swoosh: el.querySelector<HTMLElement>("[data-interstitial-swoosh]"),
      }))
      .filter(
        (t): t is { el: HTMLElement; swoosh: HTMLElement } => t.swoosh !== null,
      );

    function update() {
      const vh = window.innerHeight;
      for (const { el, swoosh } of targets) {
        const rect = el.getBoundingClientRect();
        if (rect.bottom < -vh || rect.top > vh * 2) continue;
        const total = vh + rect.height;
        const traveled = vh - rect.top;
        const prog = Math.max(0, Math.min(1, traveled / total));
        const bell = 1 - Math.abs(prog * 2 - 1);
        swoosh.style.setProperty("--isw-prog", String(prog));
        swoosh.style.setProperty("--isw-p", String(bell));
      }
    }

    let raf: number | null = null;
    function onScroll() {
      if (raf !== null) return;
      raf = requestAnimationFrame(() => {
        update();
        raf = null;
      });
    }

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();
  }
</script>
