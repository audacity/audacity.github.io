---
import HeroSwoosh from "../homepage/HeroSwoosh.astro";

interface Props {
  from?: string;
  to?: string;
}

const { from = "rgb(28, 30, 108)", to = "rgb(86, 32, 78)" } = Astro.props;
---

<section
  class="about-interstitial"
  data-interstitial
  style={`background: linear-gradient(to bottom, ${from} 0%, ${to} 100%);`}
>
  <div class="about-interstitial__inner">
    <slot>
      <div class="about-interstitial__swoosh" data-interstitial-swoosh>
        <HeroSwoosh />
      </div>
    </slot>
  </div>
</section>

<style>
  .about-interstitial {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    overflow: visible;
    position: relative;
    z-index: 1;
    contain: layout;
  }

  .about-interstitial__inner {
    max-width: 60ch;
    text-align: center;
  }

  .about-interstitial__swoosh {
    position: absolute;
    top: 50%;
    left: 50%;
    /* Height-cap the swoosh via the width → aspect-ratio chain (92vh) so it
       always fits inside the gap between the two adjacent sections' content
       and never spills into either. The previous full-size swoosh was taller
       than that gap, so centred it bled up into the section above and lowered
       it bled down into the section below — there was no position that
       contained it. Centred, this sits in the seam, clear of both. Raise the
       vh to enlarge it (at the risk of re-introducing spill), lower to shrink. */
    width: min(80vw, 1400px, 92vh);
    aspect-ratio: 669 / 554;
    transform-origin: center;
    transform: translate3d(-50%, -50%, 0);
    z-index: -1;
  }
</style>

<style is:global>
  /*
    Disable HeroSwoosh's load-time animations in the interstitial and
    replace with a paused version of swoosh-in. !important is needed
    because HeroSwoosh's scoped styles have higher specificity than
    this global rule. Each path's per-path stagger comes from --delay,
    set inline by HeroSwoosh.
  */
  [data-interstitial-swoosh] svg.hero-swoosh path {
    animation: swoosh-in 900ms cubic-bezier(0.22, 1, 0.36, 1) var(--delay)
      forwards !important;
    animation-play-state: paused !important;
  }
  /*
    When the wrapper picks up .has-entered (set by the IntersectionObserver
    below the first time the interstitial reaches the viewport), every
    path's animation un-pauses and plays at its natural pace — staggered
    by --delay, GPU-composited, not bound to scroll velocity.
  */
  [data-interstitial-swoosh].has-entered svg.hero-swoosh path {
    animation-play-state: running !important;
  }
</style>

<script>
  /*
    Scroll-triggered entrance (not scroll-scrubbed). When an interstitial
    first enters the viewport, add .has-entered to its swoosh wrapper —
    each path's CSS animation un-pauses and plays its natural 900ms +
    stagger. Sticky: once entered, the cascade doesn't replay.
  */
  const swooshes = document.querySelectorAll<HTMLElement>(
    "[data-interstitial-swoosh]",
  );
  if (swooshes.length && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("has-entered");
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0, rootMargin: "0px 0px -10% 0px" },
    );
    swooshes.forEach((el) => io.observe(el));
  } else {
    // No IntersectionObserver — show immediately so the swoosh is at least
    // present (entrance won't trigger, but the graphic isn't missing).
    swooshes.forEach((el) => el.classList.add("has-entered"));
  }
</script>
