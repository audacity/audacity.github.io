---
import HeroSwoosh from "../homepage/HeroSwoosh.astro";

interface Props {
  from?: string;
  to?: string;
}

const { from = "rgb(28, 30, 108)", to = "rgb(86, 32, 78)" } = Astro.props;
---

<section
  class="about-interstitial"
  data-interstitial
  style={`background: linear-gradient(to bottom, ${from} 0%, ${to} 100%);`}
>
  <div class="about-interstitial__inner">
    <slot>
      <div class="about-interstitial__swoosh" data-interstitial-swoosh>
        <HeroSwoosh />
      </div>
    </slot>
  </div>
</section>

<style>
  .about-interstitial {
    /* Background set inline as a gradient between adjacent sections — no
       black band, just a smooth handoff with the swoosh blooming in the
       middle. */
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    overflow: visible;
    position: relative;
    /*
      z-index: 1 so the interstitial (and its bleeding swoosh) composites
      ABOVE all adjacent section backgrounds in the root stacking context.
      Section content has z-index: 2 (set in about.astro), keeping text
      above the spill. contain: layout — NOT paint, which would clip the
      spill.
    */
    z-index: 1;
    contain: layout;
  }

  .about-interstitial__inner {
    max-width: 60ch;
    text-align: center;
  }

  /*
    Absolutely positioned and centered in the interstitial. Visibility is
    driven by the HeroSwoosh's own per-path entrance animation, which is
    paused by default and starts when the interstitial scrolls into view
    (see the global override + IntersectionObserver below). The wrapper
    itself stays fully present so it doesn't gate the entrance with its
    own fade.
  */
  .about-interstitial__swoosh {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(80vw, 1400px);
    aspect-ratio: 669 / 554;
    transform-origin: center;
    transform: translate3d(-50%, -50%, 0) scale(1.05);
    z-index: -1;
  }
</style>

<style is:global>
  /*
    Hold the swoosh paths invisible (initial keyframe state of swoosh-in)
    until the interstitial scrolls into view. .has-entered on the wrapper
    starts the per-path cascade — same fan-in animation the home-page
    hero uses, just deferred until the user reaches the transition.
    Twitch is intentionally dropped here so we don't keep an infinite
    animation running on a 38-path SVG.
  */
  [data-interstitial-swoosh] svg.hero-swoosh path {
    animation: none;
  }
  [data-interstitial-swoosh].has-entered svg.hero-swoosh path {
    animation: swoosh-in 900ms cubic-bezier(0.22, 1, 0.36, 1) var(--delay)
      forwards;
  }
</style>

<script>
  /*
    Trigger the swoosh entrance the first time each interstitial enters the
    viewport. The CSS animation does the visual work; we just add a class.
    We rootMargin slightly inside the bottom edge so the animation has a
    moment to play before the user is fully past the band.
  */
  const swooshes = document.querySelectorAll<HTMLElement>(
    "[data-interstitial-swoosh]",
  );
  if (swooshes.length && "IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("has-entered");
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0, rootMargin: "0px 0px -10% 0px" },
    );
    swooshes.forEach((el) => io.observe(el));
  } else {
    // No IntersectionObserver — show immediately so the swoosh is at least
    // present (entrance won't play, but the graphic isn't missing).
    swooshes.forEach((el) => el.classList.add("has-entered"));
  }
</script>
