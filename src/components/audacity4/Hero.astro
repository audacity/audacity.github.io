---
import PlaceholderUI from "../../assets/img/audacity4/placeholder-ui.svg";
---

<section id="main" class="h-screen snap-start snap-always overflow-hidden flex flex-col">
  <div class="max-w-screen-xl mx-6 sm:mx-16 xl:mx-auto pt-28 pb-12 flex flex-col items-center justify-center text-center gap-8 h-full">
    <div class="flex flex-col gap-6 max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 tracking-tight leading-tight hero-title">
        Meet Audacity 4
      </h1>
      <p class="text-lg md:text-xl text-slate-500 leading-relaxed font-light hero-subtitle">
        A redesigned interface, powerful new editing tools, and workflows built for modern audio production.
      </p>
      <div class="flex justify-center mt-2 hero-cta">
        <a
          href="/download"
          class="px-8 py-3.5 bg-blue-700 text-white rounded-full font-medium text-lg hover:bg-blue-600 transition-colors"
        >
          Download Audacity 4
        </a>
      </div>
    </div>

    <div class="w-full max-w-7xl hero-image flex-1 min-h-0 px-4">
      <img
        src={PlaceholderUI.src}
        alt="The new Audacity 4 interface showing a redesigned toolbar, track panel, and waveform editor"
        class="w-full max-h-full object-contain rounded-2xl shadow-[0_30px_60px_rgba(0,0,0,0.15)] border border-gray-200/50"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  .hero-title,
  .hero-subtitle,
  .hero-cta,
  .hero-image {
    opacity: 0;
    animation: heroEntrance 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-title {
    animation-delay: 0.1s;
    transform: translateY(30px);
  }

  .hero-subtitle {
    animation-delay: 0.3s;
    transform: translateY(20px);
  }

  .hero-cta {
    animation-delay: 0.5s;
    transform: translateY(20px);
  }

  .hero-image {
    animation: heroDrop 2s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
    transform: scale(2.5) translateY(30%);
  }

  @keyframes heroEntrance {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes heroDrop {
    0% {
      opacity: 0;
      transform: scale(2.5) translateY(30%);
    }
    30% {
      opacity: 1;
    }
    100% {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title,
    .hero-subtitle,
    .hero-cta,
    .hero-image {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
