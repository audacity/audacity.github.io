---
import DownloadMuseHubButton from "../button/DownloadMuseHubButton";
import { Image } from "astro:assets";
import AudacityMockUp from "../../assets/img/HeroBannerImage.webp";
import HeroSwoosh from "./HeroSwoosh.astro";
import { useTranslations } from "../../i18n";

const t = useTranslations(Astro.currentLocale);
---

<section
  id="main"
  class="py-8 md:py-12 lg:py-16"
  style="background-color: #0C013A;"
>
  <div
    class="mx-auto max-w-screen-lg lg:max-w-screen-xl xl:max-w-screen-xl px-6 md:px-16"
  >
    <div class="flex flex-col lg:flex-row lg:items-center gap-8 lg:gap-0">
      <!-- Left Column - Text Content -->
      <div
        class="flex flex-col text-center lg:text-left lg:w-2/5 gap-6 md:gap-8 lg:gap-10 xl:gap-14"
      >
        <div class="flex flex-col gap-0">
          <h1
            class="font-harmony text-32 sm:text-40 md:text-48 lg:text-56 xl:text-64 text-text-contrast leading-tight whitespace-nowrap"
          >
            {t("hero.headline1")}
          </h1>
          <h1
            class="font-harmony text-32 sm:text-40 md:text-48 lg:text-56 xl:text-64 text-text-contrast leading-tight whitespace-nowrap"
          >
            {t("hero.headline2")}
          </h1>
          <h1
            class="font-harmony text-32 sm:text-40 md:text-48 lg:text-56 xl:text-64 text-text-contrast leading-tight whitespace-nowrap"
          >
            {t("hero.headline3")}
          </h1>
        </div>

        <div class="flex flex-col gap-4 items-center lg:items-start">
          <DownloadMuseHubButton client:load />
          <noscript>
            <DownloadMuseHubButton client:load />
          </noscript>
          <a
            href="/about"
            class="font-muse-sans text-16 text-text-contrast underline underline-offset-4 decoration-text-contrast/40 hover:text-accent hover:decoration-accent transition-colors"
          >
            {t("hero.learnMore")}
          </a>
        </div>
      </div>

      <!-- Right Column - Image -->
      <div class="lg:w-3/5 flex items-center justify-center relative">
        <div
          class="pointer-events-none absolute inset-0 -inset-x-6 lg:-inset-x-12 -inset-y-8 lg:-inset-y-16 z-0"
          aria-hidden="true"
        >
          <HeroSwoosh />
        </div>
        <Image
          src={AudacityMockUp}
          alt="A laptop showing the Audacity application"
          width={1400}
          quality={90}
          loading="eager"
          class="relative z-10 w-full max-w-[400px] lg:max-w-full h-auto"
        />
      </div>
    </div>
  </div>
</section>
