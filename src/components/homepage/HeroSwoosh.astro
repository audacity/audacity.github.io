<svg
  class="hero-swoosh"
  viewBox="0 0 669 554"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  preserveAspectRatio="xMidYMid meet"
>
  {
    PATHS.map((p, i) => {
      const inDelay = i * 35;
      // Pseudo-random per-path twitch so they don't beat in unison.
      const twitchDur = 2600 + ((i * 137) % 2200);
      const twitchDelay = 1400 + ((i * 211) % 900);
      return (
        <path
          d={p.d}
          fill={p.fill}
          style={`--i:${i};--delay:${inDelay}ms;--twitch-dur:${twitchDur}ms;--twitch-delay:${twitchDelay}ms`}
        />
      );
    })
  }
</svg>

<style>
  .hero-swoosh {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .hero-swoosh path {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
    transform: scale(0.6);
    animation:
      swoosh-in 900ms cubic-bezier(0.22, 1, 0.36, 1) var(--delay) forwards,
      twitch var(--twitch-dur) ease-in-out var(--twitch-delay) infinite;
  }

  @keyframes swoosh-in {
    0% {
      opacity: 0;
      transform: scale(0.5) rotate(-12deg);
    }
    100% {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }

  /* Subtle continuous "alive" motion after the fan-in settles. The later
     animation in the list wins for transform conflicts, so this takes over
     from swoosh-in's resting state. */
  @keyframes twitch {
    0%,
    100% {
      transform: scale(1) rotate(0deg);
    }
    25% {
      transform: scale(1.015) rotate(0.8deg);
    }
    50% {
      transform: scale(0.99) rotate(-0.5deg);
    }
    75% {
      transform: scale(1.01) rotate(0.4deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-swoosh path {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
