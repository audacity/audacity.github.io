---
import "../../styles/fonts.css";
import {
  hasDownloadAssets,
  preReleaseList,
} from "../../assets/data/audacityReleases";
import MuseHubSVG from "../inlineSVG/MuseHubSVG";
import MuseGroupSVG from "../inlineSVG/MuseGroupSVG";
import AudioSVG from "../inlineSVG/AudioSVG";
import FacebookSVG from "../inlineSVG/FacebookSVG";
import InstagramSVG from "../inlineSVG/InstagramSVG";
import TwitterSVG from "../inlineSVG/TwitterSVG";
import YoutubeSVG from "../inlineSVG/YoutubeSVG";
import DiscordSVG from "../inlineSVG/DiscordSVG";
import LanguageSelector from "./LanguageSelector.astro";
import { useTranslations } from "../../i18n";

const t = useTranslations(Astro.currentLocale);
const localePrefix =
  Astro.currentLocale && Astro.currentLocale !== "en"
    ? `/${Astro.currentLocale}`
    : "";

const links = [
  { href: "/help", label: t("footer.link.help") },
  { href: "/FAQ", label: t("footer.link.faq") },
  { href: "/blog", label: t("footer.link.blog") },
  { href: "/cloud-saving", label: t("footer.link.cloudSaving") },
  {
    href: "https://forum.audacityteam.org/",
    label: t("footer.link.forum"),
    external: true,
  },
  {
    href: "https://merch.audacityteam.org/",
    label: t("footer.link.merch"),
    external: true,
    badge: "NEW",
  },
  { href: "/manual", label: t("footer.link.manual") },
  { href: "https://audio.com/", label: "Audio.com", external: true },
];

const downloads = [
  { href: "/download/windows", label: "Windows" },
  { href: "/download/mac", label: "macOS" },
  { href: "/download/linux", label: "Linux" },
  { href: "/beta", label: t("footer.download.beta"), id: "beta-link" },
  {
    href: "https://musehub.com/?utm_source=audacity&utm_medium=footer&utm_campaign=musehub",
    label: "MuseHub",
    external: true,
  },
  { href: "/download/openvino", label: t("footer.download.aiPlugins") },
];

const social = [
  {
    href: "https://www.facebook.com/Audacity/",
    label: "Facebook",
    external: true,
  },
  { href: "https://x.com/getaudacity?lang=en", label: "X", external: true },
  {
    href: "https://www.instagram.com/audacityteam/",
    label: "Instagram",
    external: true,
  },
  {
    href: "https://www.youtube.com/c/audacity",
    label: "YouTube",
    external: true,
  },
  { href: "https://discord.gg/audacity", label: "Discord", external: true },
];

const plugins = [
  { href: "/download/openvino", label: "OpenVino" },
  { href: "https://musehub.com/musefx", label: "MuseFX", external: true },
  {
    href: "https://www.landr.com/en/plugins/landr-fx-voice",
    label: "LandrFX Voice",
    external: true,
  },
  {
    href: "https://www.audionamix.com/soap-voice-cleaner/",
    label: "Soap Voice Cleaner",
    external: true,
  },
  {
    href: "https://www.auburnsounds.com/products/Graillon.html",
    label: "Graillon",
    external: true,
  },
];

const activeDownloadCampaign =
  preReleaseList.find(
    (entry) => entry.isActive && hasDownloadAssets(entry.downloads),
  ) ?? null;
const hasPreRelease = Boolean(activeDownloadCampaign);
---

<footer class="bg-background-dark py-12">
  <div class="max-w-screen-xl mx-auto px-8">
    <div class="grid grid-cols-1 lg:grid-cols-[2fr_4fr] gap-8 lg:gap-12">
      <!-- Brand Column -->
      <div class="flex flex-col justify-between">
        <div>
          <p class="font-harmony text-64 text-accent">Audacity</p>
          <p class="text-12 mt-2 text-text-contrast/75">
            Copyright &copy; <span id="copyright"></span> | {
              t("footer.copyright")
            }.
          </p>
        </div>
      </div>

      <!-- Link Groups Container -->
      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 pt-8 lg:pt-4 border-t border-text-contrast/20 lg:border-t-[1px]"
      >
        <!-- Links Column -->
        <div>
          <p class="font-harmony text-32 text-text-contrast">
            {t("footer.nav.links")}
          </p>
          <ul class="mt-2 space-y-2 md:space-y-0">
            {
              links.map((link) => (
                <li class="w-fit">
                  <a
                    href={
                      link.external ? link.href : `${localePrefix}${link.href}`
                    }
                    aria-label={
                      link.external
                        ? `External link to ${link.label}`
                        : `Link to ${link.label}`
                    }
                    target={link.external ? "_blank" : undefined}
                    class="text-text-contrast/75 hover:text-accent hover:underline transition-colors"
                  >
                    {link.badge ? <b>{link.label}</b> : link.label}
                    {link.badge && (
                      <sup class="ml-1 px-1.5 py-0.3 rounded bg-red-600 text-white text-12 font-semibold">
                        {link.badge}
                      </sup>
                    )}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Downloads Column -->
        <div>
          <p class="font-harmony text-32 text-text-contrast">
            {t("footer.nav.downloads")}
          </p>
          <ul class="mt-2 space-y-2 md:space-y-0">
            {
              downloads.map((link) => (
                <li id={link.id} class="w-fit">
                  <a
                    href={
                      link.external ? link.href : `${localePrefix}${link.href}`
                    }
                    aria-label={
                      link.external
                        ? `External link to ${link.label}`
                        : `Link to ${link.label}`
                    }
                    target={link.external ? "_blank" : undefined}
                    class="text-text-contrast/75 hover:text-accent hover:underline transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Social Column -->
        <div>
          <p class="font-harmony text-32 text-text-contrast">
            {t("footer.nav.social")}
          </p>
          <ul class="mt-2 space-y-2 md:space-y-0">
            {
              social.map((link) => (
                <li class="w-fit">
                  <a
                    href={link.href}
                    aria-label={`External link to ${link.label}`}
                    target="_blank"
                    class="text-text-contrast/75 hover:text-accent hover:underline transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Plugins Column -->
        <div>
          <p class="font-harmony text-32 text-text-contrast">
            {t("footer.nav.plugins")}
          </p>
          <ul class="mt-2 space-y-2 md:space-y-0">
            {
              plugins.map((link) => (
                <li class="w-fit">
                  <a
                    href={
                      link.external ? link.href : `${localePrefix}${link.href}`
                    }
                    aria-label={
                      link.external
                        ? `External link to ${link.label}`
                        : `Link to ${link.label}`
                    }
                    target={link.external ? "_blank" : undefined}
                    class="text-text-contrast/75 hover:text-accent hover:underline transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <!-- Social Icons Row -->
    <div
      class="mt-12 pt-8 border-t border-text-contrast/20 flex items-center justify-between"
    >
      <div class="flex gap-4">
        {
          social.map((link) => (
            <a
              href={link.href}
              aria-label={`External link to ${link.label}`}
              target="_blank"
              class="text-accent hover:text-text-contrast transition-colors"
            >
              {link.label === "Facebook" ? (
                <FacebookSVG client:load />
              ) : link.label === "Instagram" ? (
                <InstagramSVG client:load />
              ) : link.label === "X" ? (
                <TwitterSVG client:load />
              ) : link.label === "YouTube" ? (
                <YoutubeSVG client:load />
              ) : link.label === "Discord" ? (
                <DiscordSVG client:load />
              ) : (
                link.label
              )}
            </a>
          ))
        }
      </div>
      <LanguageSelector />
    </div>

    <!-- Logos Row -->
    <div
      class="mt-8 pt-8 border-t border-text-contrast/20 grid grid-cols-1 lg:grid-cols-[2fr_4fr] gap-8 lg:gap-12 items-center"
    >
      <MuseGroupSVG />
      <div class="flex gap-8 items-center">
        <MuseHubSVG />
        <AudioSVG />
      </div>
    </div>
  </div>
</footer>

<script>
  const elem = document.querySelector("#copyright");
  if (elem) elem.textContent = new Date().getFullYear().toString();
</script>
