---
// Pagefind Component UI — composes <pagefind-*> custom elements. Bundle is
// generated at build time by `pagefind --site dist`.
---

<link rel="stylesheet" href="/pagefind/pagefind-component-ui.css" />
<script is:inline src="/pagefind/pagefind-component-ui.js"></script>

<!-- Inline display fallbacks so the elements render even before the Pagefind
     CSS hydrates (e.g. if it's still loading or 404s during initial dev). -->
<style is:global>
  pagefind-config,
  pagefind-searchbox,
  pagefind-input,
  pagefind-summary,
  pagefind-results,
  pagefind-keyboard-hints {
    display: block;
  }
  pagefind-modal-trigger {
    display: block;
  }
  pagefind-modal:not([open]) {
    display: none;
  }
</style>

<pagefind-config bundle-path="/pagefind/">
  <pagefind-modal-trigger>
    <button
      type="button"
      class="w-full flex items-center gap-2 border border-gray-300 rounded-md bg-white px-3 py-2 text-sm text-gray-500 hover:border-blue-700 hover:text-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-700"
    >
      <svg
        class="w-4 h-4 shrink-0"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <span class="flex-1 text-left">Search the manual…</span>
      <kbd
        class="hidden sm:inline-block text-[10px] font-mono border border-gray-300 rounded px-1 py-0.5 text-gray-500"
      >
        /
      </kbd>
    </button>
  </pagefind-modal-trigger>

  <pagefind-modal>
    <pagefind-modal-header>
      <pagefind-input></pagefind-input>
      <pagefind-summary></pagefind-summary>
    </pagefind-modal-header>
    <pagefind-modal-body>
      <pagefind-results></pagefind-results>
    </pagefind-modal-body>
    <pagefind-modal-footer>
      <pagefind-keyboard-hints></pagefind-keyboard-hints>
    </pagefind-modal-footer>
  </pagefind-modal>
</pagefind-config>

<script is:inline>
  // "/" opens the modal from anywhere on the manual.
  document.addEventListener("keydown", (e) => {
    if (
      e.key === "/" &&
      !e.metaKey &&
      !e.ctrlKey &&
      !["INPUT", "TEXTAREA"].includes(document.activeElement?.tagName ?? "")
    ) {
      const trigger = document.querySelector("pagefind-modal-trigger button");
      if (trigger) {
        e.preventDefault();
        trigger.click();
      }
    }
  });
</script>
