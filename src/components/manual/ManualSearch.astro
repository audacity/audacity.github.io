---
// Pagefind Default UI — single input with dropdown results. Bundle is
// generated at build time by `pagefind --site dist`.
---

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>

<div id="manual-search" class="manual-search-wrapper"></div>

<style is:global>
  /* The wrapper is the positioning context for the floating results panel. */
  .manual-search-wrapper {
    position: relative;
  }
  .manual-search-wrapper .pagefind-ui__form {
    position: relative;
  }
  .manual-search-wrapper .pagefind-ui__search-input {
    background-color: white;
    border: 1px solid rgb(209 213 219);
    border-radius: 0.375rem;
    padding: 0.5rem 0.75rem 0.5rem 2rem;
    font-size: 0.875rem;
    width: 100%;
  }
  .manual-search-wrapper .pagefind-ui__search-input:focus {
    outline: none;
    border-color: rgb(29 78 216);
    box-shadow: 0 0 0 2px rgba(29, 78, 216, 0.2);
  }
  .manual-search-wrapper .pagefind-ui__search-clear {
    right: 0.5rem;
  }

  /* Float the results panel over the page content rather than pushing it
     down. Sit just below the input, take a comfortable width, scroll if
     the result list grows. */
  .manual-search-wrapper .pagefind-ui__drawer {
    position: absolute;
    left: 0;
    right: 0;
    top: calc(100% + 0.375rem);
    z-index: 40;
    min-width: 22rem;
    max-width: 32rem;
    max-height: min(70vh, 32rem);
    overflow-y: auto;
    background-color: white;
    border: 1px solid rgb(209 213 219);
    border-radius: 0.5rem;
    box-shadow:
      0 10px 15px -3px rgba(0, 0, 0, 0.1),
      0 4px 6px -4px rgba(0, 0, 0, 0.1);
    padding: 0.75rem;
  }
  /* Hide the drawer entirely when there's nothing to show (no query) so it
     doesn't render an empty floating box. */
  .manual-search-wrapper .pagefind-ui__drawer.pagefind-ui__hidden {
    display: none;
  }
  .manual-search-wrapper .pagefind-ui__result-title a {
    color: rgb(29 78 216);
  }
</style>

<script is:inline>
  (function () {
    function init() {
      var mount = document.getElementById("manual-search");
      if (!mount) return;
      if (typeof window.PagefindUI !== "function") return;
      try {
        new window.PagefindUI({
          element: "#manual-search",
          showSubResults: true,
          showImages: false,
          excerptLength: 20,
          resetStyles: false,
          placeholder: "Search the manual…",
        });
      } catch (err) {
        console.error("[ManualSearch] PagefindUI failed to initialize:", err);
        mount.innerHTML =
          '<div class="text-sm text-red-600">Search failed to load. See browser console.</div>';
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
