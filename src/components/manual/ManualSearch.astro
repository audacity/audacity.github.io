---
// Pagefind Default UI — single input with dropdown results. Bundle is
// generated at build time by `pagefind --site dist`.
---

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>

<div id="manual-search" class="manual-search-wrapper"></div>

<style is:global>
  /* Polish on top of the default UI: shave the chrome, fit it into the
     sidebar, and align typography with the rest of the site. */
  .manual-search-wrapper .pagefind-ui__form {
    position: relative;
  }
  .manual-search-wrapper .pagefind-ui__search-input {
    background-color: white;
    border: 1px solid rgb(209 213 219);
    border-radius: 0.375rem;
    padding: 0.5rem 0.75rem 0.5rem 2rem;
    font-size: 0.875rem;
    width: 100%;
  }
  .manual-search-wrapper .pagefind-ui__search-input:focus {
    outline: none;
    border-color: rgb(29 78 216);
    box-shadow: 0 0 0 2px rgba(29, 78, 216, 0.2);
  }
  .manual-search-wrapper .pagefind-ui__search-clear {
    right: 0.5rem;
  }
  .manual-search-wrapper .pagefind-ui__results-area {
    margin-top: 0.75rem;
  }
  .manual-search-wrapper .pagefind-ui__result-title a {
    color: rgb(29 78 216);
  }
</style>

<script is:inline>
  (function () {
    function init() {
      var mount = document.getElementById("manual-search");
      if (!mount) return;
      if (typeof window.PagefindUI !== "function") return;
      try {
        new window.PagefindUI({
          element: "#manual-search",
          showSubResults: true,
          showImages: false,
          excerptLength: 20,
          resetStyles: false,
          placeholder: "Search the manual…",
        });
      } catch (err) {
        console.error("[ManualSearch] PagefindUI failed to initialize:", err);
        mount.innerHTML =
          '<div class="text-sm text-red-600">Search failed to load. See browser console.</div>';
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
