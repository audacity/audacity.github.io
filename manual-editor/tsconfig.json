{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "noEmit": true,
    "esModuleInterop": true
  },
  "include": ["src"],
  "exclude": ["src/app", "src/adapter", "src/backend"]
}
